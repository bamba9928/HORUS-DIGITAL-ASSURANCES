# ─── Sécurité Django ──────────────────────────────────────────────────────────
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

DJANGO_DEBUG=False

# Domaines autorisés, séparés par virgule (ex: api.horus.sn,horus.sn)
DJANGO_ALLOWED_HOSTS=

# ─── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL obligatoire en production
# Format : postgres://user:password@host:5432/dbname
DATABASE_URL=
FRONTEND_BASE_URL=http://localhost:3000
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@horus-assurances.sn
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
# URL complète du frontend, séparées par virgule (ex: https://horus.sn)
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# ─── Throttling ───────────────────────────────────────────────────────────────
# Limite de tentatives de connexion par IP (anti force brute)
AUTH_LOGIN_THROTTLE_RATE=10/min
# Limite d'appels vérification immatriculation par utilisateur (CGU ASS)
ASS_VERIFY_THROTTLE_RATE=30/min

# ─── Sessions ─────────────────────────────────────────────────────────────────
# Durée de session en secondes (défaut : 12 h)
SESSION_COOKIE_AGE=43200

# ─── HTTPS ────────────────────────────────────────────────────────────────────
# Mettre à True uniquement après activation de HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
# True si Django est derrière un reverse proxy qui termine le TLS (nginx, traefik…)
USE_X_FORWARDED_PROTO=False

# ─── Intégration Orange Money (Paiement Marchand Sonatel) ─────────────────────
# Sandbox : https://api.sandbox.orange-sonatel.com — prod : https://api.orange-sonatel.com
OM_BASE_URL=https://api.sandbox.orange-sonatel.com
OM_CLIENT_ID=
OM_CLIENT_SECRET=
# Code marchand attribué par Sonatel à l'ouverture du compte Marchand
OM_MERCHANT_CODE=
OM_MERCHANT_NAME=HORUS ASSUR
# Durée de validité du QR de paiement (secondes)
OM_QR_VALIDITY_SECONDS=300
# Mock actif tant que les accès Sonatel ne sont pas fournis
OM_MOCK_ENABLED=True
OM_REAL_CALLS_ALLOWED=False
# Mock uniquement : délai avant confirmation simulée du paiement
OM_MOCK_CONFIRM_DELAY_SECONDS=15

# ─── Intégration ASS ──────────────────────────────────────────────────────────
# URL de base API ASS (sandbox: https://kiiraytest.lasecu-assurances.sn)
ASS_BASE_URL=
ASS_API_PARTNER_SEGMENT=
ASS_USERNAME=
ASS_PASSWORD=

# Frais de police en FCFA
ASS_POLICY_FEE=3000

# Endpoint d'annulation : /qrcode.mono.cancel (PDF) ou /qrcode.cancel (Postman).
# À fixer après confirmation d'ASS, sans redéploiement.
ASS_CANCEL_ENDPOINT=/qrcode.mono.cancel

# Seuil d'alerte stock QR (dashboard + statut low_stock)
ASS_QR_STOCK_ALERT_THRESHOLD=10

# Mettre à False en production pour activer les vrais appels ASS
ASS_MOCK_ENABLED=False
ASS_REAL_CALLS_ALLOWED=True
