# ─── Sécurité Django ──────────────────────────────────────────────────────────
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

DJANGO_DEBUG=False

# Domaines autorisés, séparés par virgule (ex: api.horus.sn,horus.sn)
DJANGO_ALLOWED_HOSTS=

# ─── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL obligatoire en production
# Format : postgres://user:password@host:5432/dbname
DATABASE_URL=

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
# URL complète du frontend, séparées par virgule (ex: https://horus.sn)
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# ─── HTTPS ────────────────────────────────────────────────────────────────────
# Mettre à True uniquement après activation de HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ─── Intégration ASS ──────────────────────────────────────────────────────────
# URL de base API ASS (sandbox: https://kiiraytest.lasecu-assurances.sn)
ASS_BASE_URL=
ASS_API_PARTNER_SEGMENT=
ASS_USERNAME=
ASS_PASSWORD=

# Frais de police en FCFA
ASS_POLICY_FEE=3000

# Mettre à False en production pour activer les vrais appels ASS
ASS_MOCK_ENABLED=False
ASS_REAL_CALLS_ALLOWED=True
